# =============================================================================
# NextFlow — copy to `.env.local` and fill every value (never commit secrets).
# =============================================================================
#
# Where to get keys (official sign-up pages):
#   Clerk        https://dashboard.clerk.com
#   Neon         https://console.neon.tech
#   Google AI    https://aistudio.google.com/apikey   (Gemini)
#   Trigger.dev  https://cloud.trigger.dev
#   Transloadit  https://transloadit.com/credentials
#
# Vercel: add the same variables in Project → Settings → Environment Variables.
# Trigger.dev: add DATABASE_URL, GOOGLE_GENERATIVE_AI_API_KEY, TRANSLOADIT_*
#   to your Trigger project so tasks (orchestrator, LLM, FFmpeg) can run.
# =============================================================================

# --- Clerk (auth) ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Neon PostgreSQL (Prisma) -----------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Google Gemini (Trigger tasks only) ------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Trigger.dev ------------------------------------------------------------
TRIGGER_SECRET_KEY=
# Project ref from dashboard (e.g. proj_xxxx). Required for `npm run trigger:dev`.
TRIGGER_PROJECT_ID=
# Optional: self-hosted Trigger API only
# TRIGGER_API_URL=https://api.trigger.dev

# --- Transloadit ------------------------------------------------------------
TRANSLOADIT_AUTH_KEY=
TRANSLOADIT_SECRET=

# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
